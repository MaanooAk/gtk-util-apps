class VideoBrowserWindow(Adw.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.set_default_size(600, 800)
        self.set_title("Video Browser")

        self.main_stack = Gtk.Box(orientation=VERTICAL)
        self.set_content(self.main_stack)

        header = Adw.HeaderBar()
        title_widget = Adw.WindowTitle(title="Video Browser")
        header.set_title_widget(title_widget)

        self.spinner = Gtk.Spinner()
        self.spinner.set_margin_start(12)
        self.spinner.set_halign(Gtk.Align.CENTER)
        self.spinner.set_valign(Gtk.Align.CENTER)
        self.spinner.set_hexpand(True)
        self.spinner.set_vexpand(True)
        self.spinner.start()

        self.spinner_label = Gtk.Label(label="sync")
        self.spinner_label.add_css_class("caption")

        header_start = Gtk.Box(orientation=HORIZONTAL, spacing=8)
        header_start.append(self.spinner)
        header_start.append(self.spinner_label)
        header.pack_start(header_start)

        self.refresh_button = Gtk.Button(icon_name="view-refresh-symbolic")
        self.refresh_button.connect("clicked", self.on_refresh_clicked)

        self.edit_channels = Gtk.Button(icon_name="view-list-symbolic")
        self.edit_channels.connect("clicked", self.on_edit_channels)

        header_end = Gtk.Box(orientation=HORIZONTAL, spacing=8)
        header_end.append(self.refresh_button)
        header_end.append(self.edit_channels)
        header.pack_end(header_end)

        self.main_stack.append(header)

        self.scrolled = Gtk.ScrolledWindow()
        self.scrolled.set_vexpand(True)
        self.main_stack.append(self.scrolled)

        self.list_box = Gtk.ListBox()
        self.list_box.set_selection_mode(Gtk.SelectionMode.NONE)
        self.list_box.add_css_class("boxed-list")
        self.list_box.set_margin_top(12)
        self.list_box.set_margin_bottom(12)
        self.list_box.set_margin_start(12)
        self.list_box.set_margin_end(12)

        self.scrolled.set_child(self.list_box)

        self.adj = self.scrolled.get_vadjustment()
        self.adj.connect("value-changed", self.on_scroll_changed)

        self.loading = False
        self.load_data()

        synced_channels = False
        synced_info = False

        global win
        win = self
        threading.Thread(target=sync_lists, daemon=True).start()

    def on_refresh_clicked(self, button):
        global synced_channels, synced_info
        if not synced_channels:
            return
        synced_channels = False
        synced_info = False
        threading.Thread(target=sync_lists, daemon=True).start()

    def on_edit_channels(self, button):
        def edit_thread():
            result = run([
                "zenity", "--text-info", "--title=Channels", "--editable", "--modal",
                "--filename", CHANNELS_FILE
            ], capture_output=True, text=True)

            if result.returncode == 0:
                with open(CHANNELS_FILE, 'w') as file:
                    file.write(result.stdout.strip())
                load_channels()
                sync_lists()
        threading.Thread(target=edit_thread, daemon=True).start()

    def load_data(self):
        # self.refresh_btn.set_sensitive(False)
        while child := self.list_box.get_first_child():
            self.list_box.remove(child)

        self.data = None
        self.limit = 0
        self.load_more()

    def reload_data(self):
        self.loading = True
        scroll_value = self.adj.get_value()

        while child := self.list_box.get_first_child():
            self.list_box.remove(child)

        self.data = fetch_videos()
        self.update_ui(self.data[:self.limit])

        win.adj.set_value(scroll_value)

    def load_more(self):
        self.loading = True

        if self.data is None:
            self.data = fetch_videos()

        self.update_ui(self.data[self.limit:self.limit+LIMIT_STEP])
        self.limit += LIMIT_STEP

    def update_ui(self, data):
        global synced_channels, synced_info

        for item in data:
            row_widget = VideoRow(item)
            self.list_box.append(row_widget)

        self.refresh_button.set_sensitive(True)
        if not synced_channels:
            self.refresh_button.set_sensitive(False)
            self.spinner.start()
            self.spinner_label.set_text("channels")
        elif not synced_info or download_threads.value > 0:
            self.spinner.start()
            self.spinner_label.set_text(
                f"info {len(list(filter(lambda x: x["date"] is None, self.data)))}")
        else:
            self.spinner.stop()
            self.spinner_label.set_text("")

        self.loading = False
        return False

    def on_scroll_changed(self, adj):
        if self.loading:
            return

        value = adj.get_value()
        upper = adj.get_upper()
        page_size = adj.get_page_size()

        threshold = 150
        if value >= (upper - page_size - threshold):
            self.load_more()


