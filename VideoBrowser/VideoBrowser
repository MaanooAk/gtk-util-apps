        thumbnail.set_pixel_size(100)
        self.append(thumbnail)

        if video_data["thumbnail"] != "NA":
            load_image_from_url(video_data["thumbnail"], thumbnail)

        vbox = Gtk.Box(orientation=VERTICAL, spacing=2)
        vbox.set_valign(Gtk.Align.CENTER)

        channel_name = channel_names[video_data["channel"]]
        channel_label = Gtk.Label(label=channel_name, xalign=0)
