        title_label.set_wrap(True)
        title_label.add_css_class("heading")
        vbox.append(title_label)

        status = []

        if video_data["date"] is not None:
            d = datetime.strptime(video_data["date"], "%Y%m%d").date()
            status.append(f"{d.year}-{d.month}-{d.day}")
            ago = (today - d)
            days, years = ago.days, round(ago.days / 365 * 10)/10
            status.append(f"{f"{years} years" if days >
