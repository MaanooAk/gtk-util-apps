def config_read_or(p, default=None):
    if not os.path.exists(p):
        if default is not None:
            return default
        raise FileNotFoundError(p)
    return open(p).read().strip()


channels = []
channel_names = dict()
win = None
synced_channels = False
synced_info = False
download_threads = Value('i', 0)

os.makedirs(CACHE_DIR, exist_ok=True)


def append_line(file_path, new_line):
    with open(file_path + ".lock", "w") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)

        with open(file_path, 'a') as f:
            f.write(new_line + '\n')


def load_channels():
    global channels
    channels.clear()
    for line in config_read_or(CHANNELS_FILE, "").split("\n"):
        line = line.strip()
        if len(line) == 0 or line[0] == "#":
            continue
        parts = line.split(" ", 1)
        channels.append(parts[0])
        channel_names[parts[0]] = parts[1] if len(parts) > 1 else parts[0]


load_channels()


def sync_list(channel):
    # return False
    print("channel", channel)

    result = Popen([
        "yt-dlp", "--flat-playlist", "--skip-download", "--force-write-archive",
        "--download-archive", ARCHIVE_FILE, "--break-on-existing",
        "--print", channel + FIELD_DESC,
        "--replace-in-metadata", "title", "[\"]", "'",
        "https://www.youtube.com/" + channel
    ], stdout=PIPE, text=True)

    added = False
    for line in result.stdout:
        append_line(VIDEOS_PENDING, line.strip())
        added = True

    print("/ channel", channel)
    return added


def sync_lists():
    global synced_channels, synced_info
    synced_channels = False
    synced_info = False

    with ThreadPoolExecutor(max_workers=20) as executor:
        futures = [executor.submit(sync_list, i) for i in channels]

        for future in as_completed(futures):
            if future.result():
                GLib.idle_add(win.reload_data)

    synced_channels = True
    GLib.idle_add(win.reload_data)


def download_info(channel, video_url, title):
    # return False
    with download_threads.get_lock():
        download_threads.value += 1

    result = run([
        "yt-dlp", "--skip-download",
        "--print", channel + FIELD_DESC,
        "--replace-in-metadata", "title", "[\"]", "'",
        video_url
    ], capture_output=True, text=True)

    with download_threads.get_lock():
        download_threads.value -= 1

    if result.returncode == 0:
        line = result.stdout.strip()
        append_line(VIDEOS_FILE, line)
    else:
        error = result.stderr.strip()
        if "confirm your age" in error:
            line = ",".join([channel, video_url, "0", "0", f"\"{title}\""])
            append_line(VIDEOS_FILE, line)
        else:
            print(error)

    GLib.idle_add(win.reload_data)


def get_video_id(video_url):
    for prefix in [
        "https://www.youtube.com/watch?v=",
        "https://www.youtube.com/shorts/",
    ]:
        if video_url.startswith(prefix):
            return video_url[len(prefix):]


def get_thumbnail_url(video_url, video_id):
    if video_url.startswith("https://www.youtube.com"):
        return f"https://i.ytimg.com/vi/{video_id}/mqdefault.jpg"
    return "NA"

def fetch_videos_file(file_path, collection):
    if not os.path.exists(file_path):
        return

    with open(file_path + ".lock", "w") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)

        with open(file_path, newline='', encoding='utf-8') as file:
            reader = csv.reader(file)
            for row in reader:
                channel, video_url, date_text, duration_text, title = row

                video_id = get_video_id(video_url)
                thumbnail_url = get_thumbnail_url(video_url, video_id)

                if duration_text != "NA":
                    seconds = round(float(duration_text))
                    duration_text = f"{seconds // 60:02d}:{seconds % 60:02d}"

                if any(i["id"] == video_id for i in collection):
                    continue

                collection.append({
                    "id": video_id,
                    "channel": channel,
                    "url": video_url,
                    "title": title,
                    "date": date_text if date_text != "NA" else None,
                    "duration": duration_text,
                    "thumbnail": thumbnail_url,
                    "mark": None,
                })

def fetch_videos():
    global synced_info

    collection = []
    if not os.path.exists(VIDEOS_FILE) and not os.path.exists(VIDEOS_PENDING):
        synced_info = True
        return collection

    fetch_videos_file(VIDEOS_FILE, collection)
    fetch_videos_file(VIDEOS_PENDING, collection)

    collection.sort(key=lambda x: x["date"] if x["date"]
                    is not None else "0", reverse=True)

    if synced_channels:
        while threading.active_count() < 12:
            target = next_to_expand(collection)
            if target is not None:
                synced_info = False

                def download_info_thread(target):
                    print("info", target["title"])
                    download_info(target["channel"], target["url"], target["title"])
                    print("/ info", target["title"])

                threading.Thread(target=download_info_thread, args=(target,),
                                 daemon=True).start()
            else:
                synced_info = True
                if os.path.exists(VIDEOS_PENDING):
                    os.remove(VIDEOS_PENDING)
                break

    return collection


fetching = set()


def next_to_expand(collection):
    channel_older = dict()

    for i in collection:
        if i["date"] is not None:
            channel_older[i["channel"]] = i["date"]
        else:
            if i["channel"] not in channel_older and i["url"] not in fetching:
                fetching.add(i["url"])
                return i

    channel = max(channel_older, key=channel_older.get)

    for i in collection:
        if i["channel"] == channel and i["date"] is None and i["url"] not in fetching:
            fetching.add(i["url"])
            return i
    for i in collection:
        if i["date"] is None and i["url"] not in fetching:
            fetching.add(i["url"])
            return i
    return None


def load_image_from_url(url, gtk_image_widget):

    path = get_cached_image_path(url, True)
    if path is not None:
        gtk_image_widget.set_from_file(path)
        return

    def fetch_thread():
        path = get_cached_image_path(url)
        if path:
            GLib.idle_add(gtk_image_widget.set_from_file, path)

    threading.Thread(target=fetch_thread, daemon=True).start()


def get_cached_image_path(url, check=False):

    ext = url.split('.')[-1] or "png"
    filename = hashlib.sha1(url.encode()).hexdigest() + f".{ext}"
    local_path = os.path.join(CACHE_DIR, filename)

    if not os.path.exists(local_path):
        if check:
            return None
        try:
            with urllib.request.urlopen(url) as response, open(local_path, 'wb') as out_file:
                out_file.write(response.read())
        except Exception as e:
            print(f"Error downloading {url}: {e}")
            return None

    return local_path


